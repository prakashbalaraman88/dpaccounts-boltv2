modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["revenuecat:1.0.0"]

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=1 RCT_METRO_PORT=5000 npx expo start --web --port 5000 --non-interactive"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "RCT_METRO_PORT=5000 npx expo start --web --port 5000 --host localhost"]

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_mVXpHKVKxBjaXOXvDVlzuaJdpKv"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_KcPGHEiokxTqWVKACPjdaUhPRMY"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_aRNerggjBfOrpWGrvUDviNcfMEm"
REVENUECAT_PROJECT_ID = "proj1c6d5152"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
