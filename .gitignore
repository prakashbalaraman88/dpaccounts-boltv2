# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# local assistant settings
.claude/
.omc/
.config/
.local/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
.worktrees/

# dotslash / devtools cache — never track binary caches
.cache/

# downloaded build tooling — JDK is re-downloaded by scripts/build-apk.sh
# (122 MB lib/modules exceeds GitHub's 100 MB file limit; must never be tracked)
/tools/

# build outputs & logs (generated; large)
*.apk
build-log.txt
build-release-log.txt
modules/*/android/build/
