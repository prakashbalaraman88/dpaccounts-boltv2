{
  "name": "interiorbooks",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./modules"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "test": "jest"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "transform": {},
        "testMatch": [
          "**/__tests__/**/*.test.js"
        ],
        "testPathIgnorePatterns": [
          "/node_modules/",
          "\\.component\\.test\\.js$"
        ]
      },
      {
        "displayName": "component",
        "preset": "jest-expo",
        "testMatch": [
          "**/__tests__/**/*.component.test.js"
        ],
        "moduleNameMapper": {
          "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
          "^react-native-vector-icons$": "@expo/vector-icons",
          "^react-native-vector-icons/(.*)$": "@expo/vector-icons/$1"
        }
      }
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@replit/connectors-sdk": "^0.4.1",
    "@replit/revenuecat-sdk": "^4.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "babel-preset-expo": "^55.0.8",
    "expo": "~55.0.26",
    "expo-auth-session": "~55.0.17",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-file-system": "~55.0.22",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.17",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-share-intent": "^6.1.1",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.17",
    "ledge-share-handler": "file:./modules/ledge-share-handler",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "private": true,
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  }
}
